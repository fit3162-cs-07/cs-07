PORT=3000
NODE_ENV=development
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Repository driver: "memory" (default, in-process) or "mongo".
# When set to "mongo", MONGODB_URI is required.
REPOSITORY_DRIVER=memory
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/cs07

# When set, CORS only accepts requests from this origin (plus localhost dev ports).
# When unset, CORS is wide-open (development default).
FRONTEND_ORIGIN=http://localhost:5173
