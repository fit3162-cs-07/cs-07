{
  "info": {
    "name": "Monash Club Task Manager API",
    "description": "Full API demo collection for FIT3162 Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "adminToken", "value": "" },
    { "key": "memberToken", "value": "" },
    { "key": "taskId", "value": "" },
    { "key": "member1Id", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "1a. Register Admin",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo.admin@monash.edu\",\n  \"name\": \"Demo Admin\",\n  \"password\": \"admin123\",\n  \"role\": \"ADMIN\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('adminToken', res.data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "1b. Register Member",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo.member@monash.edu\",\n  \"name\": \"Demo Member\",\n  \"password\": \"member123\",\n  \"role\": \"MEMBER\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('memberToken', res.data.token);",
                  "  pm.collectionVariables.set('member1Id', res.data.user.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "1c. Login (Seeded Admin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@monash.edu\",\n  \"password\": \"admin123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('adminToken', res.data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "1d. Login (Seeded Member)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"member1@monash.edu\",\n  \"password\": \"member123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('memberToken', res.data.token);",
                  "  pm.collectionVariables.set('member1Id', res.data.user.id);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Tasks (Admin)",
      "item": [
        {
          "name": "2a. Create Task",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tasks",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Prepare O-Week presentation\",\n  \"description\": \"Create slides for the orientation week club stall\",\n  \"priority\": \"HIGH\",\n  \"dueDate\": \"2026-04-15T00:00:00.000Z\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('taskId', res.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "2b. Get All Tasks",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tasks",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "2c. Get All Tasks (filter by status)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/tasks?status=TODO",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [{ "key": "status", "value": "TODO" }]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "2d. Get All Tasks (filter by priority)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/tasks?priority=HIGH",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [{ "key": "priority", "value": "HIGH" }]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "2e. Get Task by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tasks/{{taskId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "2f. Assign Task to Member",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/tasks/{{taskId}}/assign",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"assigneeId\": \"{{member1Id}}\"\n}"
            }
          }
        },
        {
          "name": "2g. Change Status → IN_PROGRESS",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/tasks/{{taskId}}/status",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}"
            }
          }
        },
        {
          "name": "2h. Change Status → DONE",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/tasks/{{taskId}}/status",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"DONE\"\n}"
            }
          }
        },
        {
          "name": "2i. Update Task",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/tasks/{{taskId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated: Prepare O-Week presentation\",\n  \"description\": \"Updated description with more details\",\n  \"priority\": \"MEDIUM\"\n}"
            }
          }
        },
        {
          "name": "2j. Delete Task",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/tasks/{{taskId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "3. RBAC Tests",
      "item": [
        {
          "name": "3a. Member tries to create task (403)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tasks",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{memberToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Unauthorized task\"\n}"
            }
          }
        },
        {
          "name": "3b. No token (401)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tasks"
          }
        },
        {
          "name": "3c. Member views tasks (200)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tasks",
            "header": [
              { "key": "Authorization", "value": "Bearer {{memberToken}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "4. Audit Log",
      "item": [
        {
          "name": "4a. Get Audit Log (Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/audit",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "4b. Get Audit Log (Member - 403)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/audit",
            "header": [
              { "key": "Authorization", "value": "Bearer {{memberToken}}" }
            ]
          }
        }
      ]
    }
  ]
}
